---
interface Props {
  title: string;
  description?: string;
  author?: string;
  date?: string;
  jsonld?: string;
  keywords?: string;
  isCitation?: boolean;
}
const { title, description, author = 'Rich Kopcho', date = 'March 2026', jsonld, keywords, isCitation = false } = Astro.props;
const pageTitle = title === 'Cumulative Computing' ? title : `${title} — Cumulative Computing`;
const canonicalUrl = Astro.url.href;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  {description && <meta name="description" content={description} />}
  <meta name="robots" content="index, follow" />
  <meta name="author" content={author} />
  {keywords && <meta name="keywords" content={keywords} />}

  <!-- Open Graph -->
  <meta property="og:title" content={pageTitle} />
  {description && <meta property="og:description" content={description} />}
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content={isCitation ? 'article' : 'website'} />
  <meta property="og:site_name" content="Cumulative Computing" />
  {isCitation && <meta property="article:author" content="https://github.com/kopcho" />}
  {isCitation && <meta property="article:published_time" content="2026-03-01" />}

  <!-- Academic citation tags (Google Scholar, Semantic Scholar) -->
  {isCitation && <meta name="citation_title" content={title} />}
  {isCitation && <meta name="citation_author" content="Kopcho, Rich" />}
  {isCitation && <meta name="citation_publication_date" content="2026/03" />}
  {isCitation && <meta name="citation_online_date" content="2026/03/01" />}
  {isCitation && <meta name="citation_language" content="en" />}
  {isCitation && <meta name="citation_fulltext_html_url" content={canonicalUrl} />}
  {isCitation && <meta name="citation_abstract_html_url" content={canonicalUrl} />}

  <link rel="canonical" href={canonicalUrl} />
  <link rel="me" href="https://github.com/kopcho" />
  <link rel="license" href="https://creativecommons.org/licenses/by/4.0/" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  {jsonld && <script type="application/ld+json" set:html={jsonld} />}
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #fafaf8;
      --bg2: #f0efe9;
      --text: #1a1a1a;
      --text-muted: #666;
      --accent: #2a4db5;
      --accent-high: #1a3a9e;
      --border: #ddddd8;
      --font-body: Georgia, 'Times New Roman', serif;
      --font-mono: 'IBM Plex Mono', 'Courier New', monospace;
    }
    html { background: var(--bg); color: var(--text); font-family: var(--font-body); font-size: 18px; line-height: 1.7; }
    body { min-height: 100vh; display: flex; flex-direction: column; }
    a { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }
    a:hover { color: var(--accent-high); }
    nav {
      border-bottom: 1px solid var(--border);
      padding: 1rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-family: var(--font-mono);
      font-size: 0.875rem;
    }
    nav a { text-decoration: none; }
    nav .site-name { color: var(--text); font-weight: 500; letter-spacing: 0.02em; }
    nav .site-name:hover { color: var(--accent); }
    nav .nav-links { display: flex; gap: 1.5rem; align-items: center; }
    nav .nav-links a { color: var(--text-muted); }
    nav .nav-links a:hover { color: var(--text); }
    .hamburger { display: none; background: none; border: none; cursor: pointer; padding: 0.25rem; color: var(--text); }
    .hamburger span { display: block; width: 22px; height: 2px; background: currentColor; margin: 5px 0; transition: all 0.2s; }
    .hamburger[aria-expanded="true"] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .hamburger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
    .hamburger[aria-expanded="true"] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
    main { flex: 1; max-width: 760px; margin: 0 auto; padding: 3rem 2rem 6rem; width: 100%; }
    footer { border-top: 1px solid var(--border); padding: 2rem; text-align: center; font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-muted); }
    footer a { color: var(--text-muted); }
    footer a:hover { color: var(--text); }
    h1 { font-size: 2rem; font-weight: bold; line-height: 1.2; margin-bottom: 1rem; color: var(--text); letter-spacing: -0.02em; }
    h2 { font-size: 1.4rem; font-weight: bold; margin: 2.5rem 0 0.75rem; color: var(--text); }
    h3 { font-size: 1.1rem; font-weight: bold; margin: 2rem 0 0.5rem; color: var(--text); }
    p { margin-bottom: 1.25rem; }
    ul, ol { margin: 0 0 1.25rem 1.5rem; }
    li { margin-bottom: 0.4rem; }
    blockquote { border-left: 3px solid var(--accent); padding: 0.75rem 1.25rem; margin: 1.5rem 0; background: var(--bg2); border-radius: 0 4px 4px 0; font-style: italic; color: var(--text-muted); }
    code { font-family: var(--font-mono); font-size: 0.85em; background: var(--bg2); padding: 0.15em 0.4em; border-radius: 3px; color: var(--text); }
    pre { background: var(--bg2); border: 1px solid var(--border); border-radius: 6px; padding: 1.25rem; overflow-x: auto; margin: 1.5rem 0; }
    pre code { background: none; padding: 0; color: var(--text); }
    hr { border: none; border-top: 1px solid var(--border); margin: 2.5rem 0; }
    table { width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: 0.9rem; }
    th, td { border: 1px solid var(--border); padding: 0.6rem 0.875rem; text-align: left; }
    th { background: var(--bg2); color: var(--text); font-family: var(--font-mono); font-weight: 500; }
    strong { color: var(--text); font-weight: bold; }
    .byline { font-family: var(--font-mono); font-size: 0.8rem; color: var(--text-muted); margin-bottom: 2.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border); display: flex; gap: 1.5rem; flex-wrap: wrap; align-items: center; }
    .byline a { color: var(--text-muted); text-decoration: none; }
    .byline a:hover { color: var(--accent); }
    .paper-nav { display: flex; justify-content: space-between; margin-top: 4rem; padding-top: 2rem; border-top: 1px solid var(--border); font-family: var(--font-mono); font-size: 0.8rem; gap: 1rem; }
    .paper-nav a { color: var(--text-muted); text-decoration: none; max-width: 45%; }
    .paper-nav a:hover { color: var(--accent); }
    .paper-nav .next { text-align: right; margin-left: auto; }
    @media (max-width: 640px) {
      html { font-size: 16px; }
      nav { padding: 0.75rem 1rem; flex-wrap: wrap; }
      .hamburger { display: block; }
      nav .nav-links {
        display: none;
        flex-direction: column;
        gap: 0.75rem;
        width: 100%;
        padding: 0.75rem 0 0.25rem;
      }
      nav .nav-links.open { display: flex; }
      main { padding: 1.5rem 1rem 4rem; }
      h1 { font-size: 1.5rem; }
      h2 { font-size: 1.25rem; }
      table { display: block; overflow-x: auto; -webkit-overflow-scrolling: touch; }
      .byline { gap: 0.75rem; }
      .paper-nav { flex-direction: column; gap: 0.75rem; }
      .paper-nav .next { text-align: left; margin-left: 0; }
    }
  </style>
</head>
<body>
  <nav>
    <a href="/" class="site-name">Cumulative Computing</a>
    <button class="hamburger" aria-label="Toggle menu" aria-expanded="false" aria-controls="nav-links">
      <span></span><span></span><span></span>
    </button>
    <div class="nav-links" id="nav-links">
      <a href="/framework/">Framework</a>
      <a href="/cite/">Cite</a>
      <a href="/interest/">Get Involved</a>
      <a href="https://github.com/kopcho/AAA" target="_blank" rel="noopener">GitHub ↗</a>
    </div>
  </nav>
  <script>
    const btn = document.querySelector('.hamburger');
    const links = document.getElementById('nav-links');
    btn?.addEventListener('click', () => {
      const open = links?.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(open));
    });
  </script>
  <main>
    <slot />
  </main>
  <footer>
    <p>© 2026 Rich Kopcho · <a href="https://github.com/kopcho/AAA">github.com/kopcho/AAA</a> · CC BY 4.0</p>
    <p style="margin-top:0.5rem;">Investor inquiries: <a href="mailto:rich@cumulativecomputing.org">rich@cumulativecomputing.org</a></p>
  </footer>
</body>
</html>
